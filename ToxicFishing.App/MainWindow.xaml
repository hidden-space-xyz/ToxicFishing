<Window
    x:Class="ToxicFishing.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ToxicFishing"
    Width="1200"
    Height="750"
    Icon="/Resources/ToxicFishing.ico"
    MinWidth="820"
    MinHeight="520"
    Background="{StaticResource BgBrush}"
    FontFamily="Segoe UI"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="40"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Custom title bar (caption)  -->
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Orientation="Horizontal"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <Button
                Click="OnMinimize"
                Content="&#xE921;"
                Style="{StaticResource CaptionButton}"
                ToolTip="Minimize" />
            <Button
                x:Name="MaxRestoreButton"
                Click="OnMaximizeRestore"
                Content="&#xE922;"
                Style="{StaticResource CaptionButton}"
                ToolTip="Maximize" />
            <Button
                Click="OnClose"
                Content="&#xE8BB;"
                Style="{StaticResource CloseCaptionButton}"
                ToolTip="Close" />
        </StackPanel>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="20,4,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
        <Grid Grid.Row="0" Margin="4,0,4,18">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Text="🎣" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Text="ToxicFishing" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource MutedBrush}"
                        Text="Automated fishing assistant" />
                </StackPanel>
            </StackPanel>

            <!--  Status pill  -->
            <Border
                Padding="14,8"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Ellipse
                        Width="10"
                        Height="10"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource MutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{Binding StatusText}" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  Body  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Controls  -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <!--  Start / Stop  -->
                    <Grid>
                        <Button
                            Command="{Binding StartCommand}"
                            Content="▶  Start bot"
                            Style="{StaticResource StartButton}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToCollapsed}}" />
                        <Button
                            Command="{Binding StopCommand}"
                            Content="■  Stop bot"
                            Style="{StaticResource StopButton}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisible}}" />
                    </Grid>

                    <!--  Live clock  -->
                    <Grid Margin="2,16,2,0">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock
                                Margin="0,0,0,4"
                                Style="{StaticResource SectionTitle}"
                                Text="UPTIME" />
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="22"
                                FontWeight="Bold"
                                Text="{Binding ElapsedText}" />
                        </StackPanel>
                        <TextBlock
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="{Binding RemainingText}" />
                    </Grid>

                    <Separator Margin="0,18" Background="{StaticResource BorderBrush}" />

                    <!--  Schedule  -->
                    <TextBlock Style="{StaticResource SectionTitle}" Text="SCHEDULED RUN TIME" />
                    <CheckBox Content="Stop automatically after a set time" IsChecked="{Binding ScheduleEnabled}" />
                    <StackPanel
                        Margin="0,12,0,0"
                        IsEnabled="{Binding ScheduleEnabled}"
                        Orientation="Horizontal">
                        <TextBox
                            Width="80"
                            VerticalContentAlignment="Center"
                            Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                            TextAlignment="Center" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource MutedBrush}"
                            Text="minutes" />
                    </StackPanel>

                    <Separator Margin="0,18" Background="{StaticResource BorderBrush}" />

                    <!--  Game window  -->
                    <TextBlock Style="{StaticResource SectionTitle}" Text="GAME WINDOW" />
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        Foreground="{StaticResource MutedBrush}"
                        Text="Pick the World of Warcraft window the bot should drive."
                        TextWrapping="Wrap" />
                    <ComboBox
                        Margin="0,0,0,10"
                        ItemsSource="{Binding Processes}"
                        SelectedItem="{Binding SelectedProcess}" />
                    <Button
                        Command="{Binding RefreshProcessesCommand}"
                        Content="↻  Refresh windows"
                        Style="{StaticResource GhostButton}" />

                    <Separator Margin="0,18" Background="{StaticResource BorderBrush}" />

                    <!--  Bobber  -->
                    <TextBlock Style="{StaticResource SectionTitle}" Text="BOBBER TEMPLATE" />
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        Foreground="{StaticResource MutedBrush}"
                        Text="Swap the bobber image to retune detection on the fly."
                        TextWrapping="Wrap" />
                    <Border
                        Margin="0,0,0,10"
                        Padding="10,8"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="8">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="12"
                            Text="{Binding BobberFileName}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Button
                        Command="{Binding ChangeBobberCommand}"
                        Content="Change bobber…"
                        Style="{StaticResource GhostButton}" />
                </StackPanel>
            </Border>

            <!--  Activity log  -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock
                            Margin="0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SectionTitle}"
                            Text="ACTIVITY" />
                        <Button
                            Width="80"
                            Height="30"
                            HorizontalAlignment="Right"
                            Command="{Binding ClearCommand}"
                            Content="Clear"
                            Style="{StaticResource GhostButton}" />
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <ListBox
                            x:Name="ActivityList"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding ActivityEntries}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="6,2" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="12.5"
                                        Text="{Binding Display}"
                                        TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#FFE3B341" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>
